{
  "name": "design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "validate-tokens": "node scripts/validate-tokens.mjs",
    "sync-tokens": "node scripts/sync-figma-tokens.mjs && npm run validate-tokens",
    "sync-tokens-mcp": "claude -p '/sync-tokens'",
    "sync-and-dev": "npm run sync-tokens && npm run dev",
    "sync-and-storybook": "npm run sync-tokens && npm run storybook",
    "storybook-mcp": "npx @storybook/mcp"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/mcp": "^0.7.0",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "oxlint": "^1.69.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
